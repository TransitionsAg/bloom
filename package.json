{
	"name": "@transitionsag/bloom",
	"version": "0.0.1",
	"packageManager": "pnpm@11.4.0",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/TransitionsAg/bloom"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && pnpm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test": "vitest --run",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.4.0",
			"onFail": "download"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		},
		"./accordion": "./dist/accordion/index.js",
		"./alert-dialog": "./dist/alert-dialog/index.js",
		"./aspect-ratio": "./dist/aspect-ratio/index.js",
		"./avatar": "./dist/avatar/index.js",
		"./bits-config": "./dist/bits-config/index.js",
		"./button": "./dist/button/index.js",
		"./calendar": "./dist/calendar/index.js",
		"./card": "./dist/card/index.js",
		"./checkbox": "./dist/checkbox/index.js",
		"./collapsible": "./dist/collapsible/index.js",
		"./combobox": "./dist/combobox/index.js",
		"./command": "./dist/command/index.js",
		"./context-menu": "./dist/context-menu/index.js",
		"./date-field": "./dist/date-field/index.js",
		"./date-picker": "./dist/date-picker/index.js",
		"./date-range-field": "./dist/date-range-field/index.js",
		"./date-range-picker": "./dist/date-range-picker/index.js",
		"./dialog": "./dist/dialog/index.js",
		"./dropdown-menu": "./dist/dropdown-menu/index.js",
		"./input": "./dist/input/index.js",
		"./label": "./dist/label/index.js",
		"./link-preview": "./dist/link-preview/index.js",
		"./menubar": "./dist/menubar/index.js",
		"./meter": "./dist/meter/index.js",
		"./navigation-menu": "./dist/navigation-menu/index.js",
		"./pagination": "./dist/pagination/index.js",
		"./pin-input": "./dist/pin-input/index.js",
		"./popover": "./dist/popover/index.js",
		"./portal": "./dist/portal/index.js",
		"./progress": "./dist/progress/index.js",
		"./radio-group": "./dist/radio-group/index.js",
		"./range-calendar": "./dist/range-calendar/index.js",
		"./rating-group": "./dist/rating-group/index.js",
		"./scroll-area": "./dist/scroll-area/index.js",
		"./select": "./dist/select/index.js",
		"./separator": "./dist/separator/index.js",
		"./stepper": "./dist/stepper/index.js",
		"./slider": "./dist/slider/index.js",
		"./switch": "./dist/switch/index.js",
		"./tabs": "./dist/tabs/index.js",
		"./time-field": "./dist/time-field/index.js",
		"./time-range-field": "./dist/time-range-field/index.js",
		"./toggle": "./dist/toggle/index.js",
		"./toggle-group": "./dist/toggle-group/index.js",
		"./toolbar": "./dist/toolbar/index.js",
		"./tooltip": "./dist/tooltip/index.js",
		"./theme.css": "./dist/theme/theme.css"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.2.1",
		"@storybook/addon-a11y": "^10.4.1",
		"@storybook/addon-docs": "^10.4.1",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.4.1",
		"@storybook/sveltekit": "^10.4.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.9.1",
		"@vitest/browser-playwright": "^4.1.3",
		"@vitest/coverage-v8": "^4.1.3",
		"playwright": "^1.59.1",
		"publint": "^0.3.18",
		"storybook": "^10.4.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0"
	},
	"keywords": [
		"svelte"
	],
	"dependencies": {
		"@internationalized/date": "^3.12.1",
		"bits-ui": "^2.18.1",
		"cva": "1.0.0-beta.4",
		"phosphor-svelte": "^3.1.0"
	}
}
